# ============================================================
# ShowDrive — Environment Template
# Salin file ini ke .env lalu isi sesuai environment kamu:
#   cp .env.example .env
#   php artisan key:generate
# ============================================================

APP_NAME=ShowDrive
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/Tugas_Akhir/ShowDrive_Project1/public
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ============================================================
# LOGGING
# ============================================================
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================
# DATABASE
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=showdrive
DB_USERNAME=root
DB_PASSWORD=

# ============================================================
# SESSION
# Development  : SESSION_DRIVER=file
# Production   : SESSION_DRIVER=database
#   (jalankan: php artisan session:table && php artisan migrate)
# ============================================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ============================================================
# CACHE
# Development  : CACHE_STORE=file
# Production   : CACHE_STORE=redis atau database
# ============================================================
CACHE_STORE=file

QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ============================================================
# MAIL
# Development  : MAIL_MAILER=log
# Production   : MAIL_MAILER=smtp / mailgun / ses
# ============================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@showdrive.id"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# REDIS (opsional)
# ============================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================
# AWS S3 (opsional — untuk cloud storage)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
